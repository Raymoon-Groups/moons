{
  "name": "moons",
  "private": true,
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "db:up": "docker compose up -d",
    "db:down": "docker compose down",
    "db:migrate": "pnpm --filter @moons/api exec prisma migrate deploy",
    "db:migrate:dev": "pnpm --filter @moons/api exec prisma migrate dev",
    "db:seed": "pnpm --filter @moons/api exec prisma db seed",
    "db:generate": "pnpm --filter @moons/api exec prisma generate",
    "db:studio": "pnpm --filter @moons/api exec prisma studio"
  },
  "devDependencies": {
    "turbo": "^2.5.4",
    "typescript": "^5.8.3"
  },
  "packageManager": "pnpm@10.12.1",
  "engines": {
    "node": ">=20"
  }
}
