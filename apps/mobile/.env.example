# Copy to .env for local overrides
# Physical device: use your PC's LAN IP, e.g. http://192.168.1.5:3001/api/v1
# Android emulator default is handled in lib/config.ts (10.0.2.2)
# Laptop browser preview can use localhost
EXPO_PUBLIC_API_URL=http://localhost:3001/api/v1

# Same Google OAuth client as web (from .env.example at repo root)
EXPO_PUBLIC_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
