# Database
DATABASE_URL=postgresql://moons:moons@localhost:5432/moons?schema=public

# Redis
REDIS_URL=redis://localhost:6379

# API
API_PORT=3001
JWT_ACCESS_SECRET=change-me-access-secret-min-32-chars
JWT_REFRESH_SECRET=change-me-refresh-secret-min-32-chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
CORS_ORIGIN=http://localhost:3000
# Production: your Vercel URL, e.g. https://moons-web.vercel.app
GOOGLE_CLIENT_ID=900368374913-pek10lel7fsk1tcmknrfna6j532o6goh.apps.googleusercontent.com

# Email (OTP verification) via Resend SMTP. Leave SMTP_HOST empty to log OTPs in API console (dev).
# Resend → API Keys → Create API Key (Sending access)
#   SMTP_USER = resend (always this literal)
#   SMTP_PASS = your Resend API key (starts with re_)
SMTP_HOST=smtp.resend.com
SMTP_PORT=465
SMTP_USER=resend
SMTP_PASS=
SMTP_FROM="MoonsJob <noreply@moonsjob.com>"

# Web
NEXT_PUBLIC_API_URL=http://localhost:3001/api/v1
NEXT_PUBLIC_GOOGLE_CLIENT_ID=900368374913-pek10lel7fsk1tcmknrfna6j532o6goh.apps.googleusercontent.com

# Mobile (Expo) — use your PC LAN IP on a physical device
EXPO_PUBLIC_API_URL=http://localhost:3001/api/v1
